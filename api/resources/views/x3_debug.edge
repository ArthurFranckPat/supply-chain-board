<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>X3 Debug — Modèles</title>
  <style>
    * { box-sizing: border-box; }
    body { font-family: monospace; font-size: 13px; background: #0f0f0f; color: #e0e0e0; margin: 0; padding: 20px; }
    h1 { color: #7eb8f7; margin-bottom: 24px; }
    .section { margin-bottom: 40px; }
    h2 { color: #aef; font-size: 14px; margin-bottom: 8px; border-bottom: 1px solid #333; padding-bottom: 4px; }
    table { border-collapse: collapse; width: 100%; }
    th { background: #1e1e1e; color: #888; text-align: left; padding: 4px 10px; border: 1px solid #2a2a2a; font-weight: normal; }
    td { padding: 4px 10px; border: 1px solid #1e1e1e; color: #cfc; white-space: nowrap; }
    tr:nth-child(even) td { background: #0d0d0d; }
    .empty { color: #555; font-style: italic; }
    .error { color: #f77; font-style: italic; }
  </style>
</head>
<body>
  <h1>X3 Debug — 5 premières lignes par modèle</h1>

  @each(section in sections)
    <div class="section">
      <h2>{{ section.title }}</h2>
      @if(section.error)
        <p class="error">Erreur: {{ section.error }}</p>
      @elseif(section.rows.length === 0)
        <p class="empty">Aucune donnée</p>
      @else
        <table>
          <thead>
            <tr>
              @each(col in section.cols)
                <th>{{ col }}</th>
              @end
            </tr>
          </thead>
          <tbody>
            @each(row in section.rows)
              <tr>
                @each(col in section.cols)
                  <td>{{ row[col] ?? '—' }}</td>
                @end
              </tr>
            @end
          </tbody>
        </table>
      @end
    </div>
  @end
</body>
</html>
