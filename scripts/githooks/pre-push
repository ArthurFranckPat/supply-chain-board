#!/bin/sh
# pre-push hook — blocks push if lint or tests fail
# Install: ./scripts/install-hooks.sh

set -e

echo "🔍 Running pre-push checks..."

# --- Frontend TypeScript ---
echo "  → tsc --noEmit (board-ui)"
cd apps/board-ui
npx tsc --noEmit
cd ../..

# --- Backend ---
cd apps/planning-engine

# --- Lint ---
echo "  → ruff check production_planning/"
python -m ruff check production_planning/
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Ruff lint failed. Fix errors before pushing."
    echo "   Run: python -m ruff check production_planning/ --fix"
    exit 1
fi

# --- Tests ---
echo "  → pytest tests/ -q"
python -m pytest tests/ -q
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Tests failed. Fix before pushing."
    exit 1
fi

cd ../..

echo ""
echo "✅ All checks passed. Pushing..."
exit 0
