{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "exports": {
    "./data": "./.adonisjs/client/data.d.ts",
    "./registry": "./.adonisjs/client/registry/index.ts"
  },
  "scripts": {
    "start": "dotenvx run -- node bin/server.js",
    "build": "dotenvx run -- node ace build",
    "dev": "dotenvx run -- node ace serve --hmr",
    "test": "dotenvx run -- node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit && tsc -p inertia-react/tsconfig.json --noEmit",
    "routes:gen": "node scripts/gen-routes-manifest.mjs",
    "routes:check": "node scripts/gen-routes-manifest.mjs && git diff --exit-code inertia/lib/routes-manifest.ts",
    "mcp:start": "dotenvx run -q -- node --import @poppinss/ts-exec bin/mcp_supply.ts"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/x3/*": "./app/models/x3/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#app/domain/*": "./app/domain/*.js",
    "#app/repositories/*": "./app/repositories/*.js",
    "#app/x3/client/*": "./app/x3/client/*.js",
    "#app/x3/*": "./app/x3/*.js",
    "#repositories/*": "./app/repositories/*.js",
    "#types/*": "./app/types/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.1.0",
    "@adonisjs/prettier-config": "^1.5.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@babel/core": "^7.29.7",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/luxon": "^3.7.2",
    "@types/node": "~25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "babel-preset-solid": "^1.9.12",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "esbuild-plugin-solid": "^0.6.0",
    "eslint": "^10.6.0",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "youch": "^4.1.1"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/cache": "^2.1.0",
    "@adonisjs/core": "^7.3.4",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/inertia": "^4.2.0",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/redis": "^10.0.0",
    "@adonisjs/session": "^8.1.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/vite": "^5.1.1",
    "@ai-sdk/react": "^4.0.34",
    "@atlaskit/pragmatic-drag-and-drop": "^2.0.1",
    "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^3.0.0",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^2.0.0",
    "@base-ui/react": "^1.6.0",
    "@dotenvx/dotenvx": "^1.75.1",
    "@earendil-works/pi-ai": "^0.80.10",
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.3.0",
    "@inertiajs/core": "^3.6.0",
    "@inertiajs/react": "^3.6.1",
    "@japa/api-client": "^3.2.1",
    "@kobalte/core": "^0.13.12",
    "@kodehort/ai-sdk-solid": "^1.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.6",
    "@tanstack/solid-table": "^8.21.3",
    "@tanstack/solid-virtual": "^3.13.32",
    "@tuyau/core": "^1.2.2",
    "@vinejs/vine": "^4.4.0",
    "ai": "^6.0.230",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cva": "^1.0.0-beta.4",
    "date-fns": "^4.4.0",
    "edge.js": "^6.5.1",
    "lucide-react": "^1.25.0",
    "luxon": "^3.7.2",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "shadcn": "^4.13.1",
    "solid-js": "^1.9.14",
    "solid-sonner": "^0.3.1",
    "sonner": "^2.0.7",
    "sqlite3": "^6.0.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.6",
    "vite-plugin-solid": "^2.11.12",
    "zustand": "^5.0.14"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config",
  "overrides": {
    "@adonisjs/inertia": {
      "@inertiajs/react": "$@inertiajs/react"
    }
  }
}
