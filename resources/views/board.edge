<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Ordonnancement OF — Gantt</title>
  <script src="/vendor/unpoly.js"></script>
  <link rel="stylesheet" href="/vendor/unpoly.css">
  <style>
    :root {
      --bg: #eef1f5;
      --panel: #ffffff;
      --line: #d3d8e0;
      --line-soft: #e7eaf0;
      --txt: #1f2733;
      --muted: #6b7480;
      --aldes: #0069B4;
      --aldes-soft: rgba(0, 105, 180, 0.10);
      --wk: #8b97a8;  /* séparateur de semaine */
      --st1: #2e9e00;  /* Ferme */
      --st2: #0069B4;  /* Planifie */
      --st3: #d98200;  /* Suggere */

      --label-w: 180px;
      --lane-h: 30px;
    }
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, system-ui, "Segoe UI", sans-serif;
      font-size: 13px; background: var(--bg); color: var(--txt); margin: 0;
    }

    header {
      display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
      background: var(--panel); border-bottom: 1px solid var(--line); padding: 10px 18px;
    }
    header h1 { font-size: 15px; margin: 0; color: var(--txt); }
    header h1 b { color: var(--aldes); }
    header .meta { color: var(--muted); font-size: 12px; }
    header form { display: flex; align-items: center; gap: 8px; }
    input, button {
      background: #fff; color: var(--txt); border: 1px solid var(--line);
      border-radius: 4px; padding: 5px 8px; font-size: 12px;
    }
    button { cursor: pointer; background: var(--aldes); color: #fff; border-color: var(--aldes); }
    button:hover { filter: brightness(1.08); }
    .legend { display: flex; gap: 12px; align-items: center; font-size: 11px; color: var(--muted); }
    .legend span { display: inline-flex; align-items: center; gap: 4px; }
    .dot { width: 9px; height: 9px; border-radius: 2px; display: inline-block; }

    /* Toolbar: search */
    .toolbar { display: flex; align-items: center; gap: 10px; padding: 8px 18px; background: var(--panel); border-bottom: 1px solid var(--line); }
    #search { flex: 0 1 420px; }
    .toolbar .hint { color: var(--muted); font-size: 11px; }
    .toggle { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; color: var(--txt); cursor: pointer; user-select: none; }
    .toggle input { accent-color: var(--aldes); }

    /* Backlog strip */
    .backlog { display: flex; gap: 6px; overflow-x: auto; padding: 8px 18px; background: #f6f8fb; border-bottom: 1px solid var(--line); min-height: 54px; align-items: stretch; }
    .backlog .bl-title { flex: 0 0 auto; color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: .5px; align-self: center; margin-right: 4px; }
    .backlog .bl-title b { color: var(--aldes); }
    .backlog.drop-hover { background: var(--aldes-soft); }
    .backlog .empty { color: var(--muted); font-style: italic; align-self: center; }

    .card {
      flex: 0 0 auto; max-width: 200px;
      background: #fff; border: 1px solid var(--line); border-left-width: 3px;
      border-radius: 4px; padding: 4px 7px; cursor: grab; font-size: 11px; line-height: 1.3; user-select: none;
      box-shadow: 0 1px 2px rgba(16,24,40,.06);
    }
    .card.st-1 { border-left-color: var(--st1); background: #eaf6e2; border-color: #c2deac; }
    .card.st-2 { border-left-color: var(--st2); background: #e4effb; border-color: #aecfee; }
    .card.st-3 { border-left-color: var(--st3); background: #fbefda; border-color: #eed4a0; }
    .card .num { font-weight: 600; color: var(--txt); }
    .card .art { color: var(--aldes); margin-left: 5px; }
    .card .qty { color: var(--muted); margin-left: 5px; }

    /* Gantt */
    .gantt {
      overflow: auto; height: calc(100vh - 0px);
      /* La largeur d'un jour remplit l'espace dispo ; min 48px sinon scroll horizontal */
      --day-w: max(48px, calc((100vw - var(--label-w) - 18px) / var(--cols)));
    }
    .ghead, .row { display: flex; width: max-content; }
    .ghead { position: sticky; top: 0; z-index: 30; background: #f1f4f8; border-bottom: 1px solid var(--line); align-items: stretch; }
    .corner, .lbl {
      position: sticky; left: 0; z-index: 5;
      flex: 0 0 var(--label-w); padding: 6px 10px; background: #f1f4f8;
      border-right: 1px solid var(--line); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .ghead .corner { z-index: 35; color: var(--muted); font-size: 11px; display: flex; flex-direction: column; justify-content: space-between; }
    .corner .ctop { font-weight: 600; }
    .corner .cbot { color: #97a0ac; }

    .hstack { display: flex; flex-direction: column; }
    .wrow { display: flex; }
    .wcell {
      text-align: center; font-size: 10px; font-weight: 700; color: var(--txt);
      background: #e3eaf2; border-right: 2px solid var(--wk); border-bottom: 1px solid var(--line-soft);
      padding: 3px 0; letter-spacing: .3px;
    }
    .wcell:last-child { border-right: 1px solid var(--line-soft); }
    .dcols { display: flex; }
    .dcol {
      flex: 0 0 var(--day-w); padding: 4px 2px 5px; text-align: center;
      color: var(--muted); border-right: 1px solid var(--line-soft); white-space: nowrap;
      display: flex; flex-direction: column; gap: 1px; line-height: 1.2;
    }
    .dcol .dwd { font-size: 10px; text-transform: capitalize; }
    .dcol .ddt { font-size: 11px; color: var(--txt); font-weight: 600; }
    .dcol .dh { font-size: 10px; color: var(--aldes); font-variant-numeric: tabular-nums; }
    .dcol.wk-start { border-left: 2px solid var(--wk); }

    .row { border-bottom: 1px solid var(--line-soft); background: var(--panel); }
    .row:hover .lbl { background: #e9eef5; }
    .lbl { color: var(--txt); font-size: 12px; display: flex; flex-direction: column; justify-content: center; background: var(--panel); }
    .lbl .code { color: var(--muted); font-size: 10px; }
    .row.hide { display: none; }

    .track {
      position: relative; flex: 0 0 calc(var(--cols) * var(--day-w));
      background: repeating-linear-gradient(to right,
        transparent 0, transparent calc(var(--day-w) - 1px),
        var(--line-soft) calc(var(--day-w) - 1px), var(--line-soft) var(--day-w));
      padding: 3px 0;
    }
    .track.drop-hover { outline: 1px dashed var(--aldes); outline-offset: -2px; }
    /* Démarcation de semaine */
    .wksep { position: absolute; top: 0; bottom: 0; width: 0; border-left: 2px solid var(--wk); pointer-events: none; z-index: 1; }

    .bar {
      position: absolute; height: calc(var(--lane-h) - 6px);
      background: #fff; border: 1px solid var(--line); border-left: 3px solid var(--muted);
      border-radius: 4px; padding: 0 6px; display: flex; align-items: center; gap: 6px;
      font-size: 11px; white-space: nowrap; overflow: hidden; cursor: grab; user-select: none;
      box-shadow: 0 1px 3px rgba(16,24,40,.18);
    }
    .bar:active { cursor: grabbing; }
    .bar:hover { box-shadow: 0 2px 6px rgba(16,24,40,.28); z-index: 4; }
    .bar.dragging { opacity: .4; }
    .bar.st-1 { border-left-color: var(--st1); background: #eaf6e2; border-color: #bcdca4; }
    .bar.st-2 { border-left-color: var(--st2); background: #e1edfa; border-color: #a6cbed; }
    .bar.st-3 { border-left-color: var(--st3); background: #fbedd4; border-color: #ecd198; }

    /* Mode compact : OF sur 1 seul jour, contenu empilé (lisible même étroit) */
    .gantt.compact { --lane-h: 48px; }
    .gantt.compact .bar {
      width: calc(1 * var(--day-w) - 5px) !important;
      height: calc(var(--lane-h) - 6px);
      flex-direction: column; align-items: flex-start; justify-content: center;
      gap: 1px; padding: 3px 6px;
      border-radius: 4px !important; border-left-style: solid !important;
    }
    .gantt.compact .bar > span {
      max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; line-height: 1.2;
    }
    .gantt.compact .bar .num { font-size: 11px; }
    .gantt.compact .bar .art { font-size: 10px; }
    .gantt.compact .bar .qty { margin-left: 0; font-size: 10px; }
    .bar .num { font-weight: 600; color: var(--txt); }
    .bar .art { color: var(--aldes); }
    .bar .qty { color: var(--muted); margin-left: auto; }
    .bar.mod { box-shadow: inset 0 0 0 1px var(--aldes), 0 1px 2px rgba(16,24,40,.10); }
    .bar.cont-left { border-top-left-radius: 0; border-bottom-left-radius: 0; border-left-style: dashed; }
    .bar.cont-right { border-top-right-radius: 0; border-bottom-right-radius: 0; }
    .bar.dim, .card.dim { opacity: .15; }

    .empty-board { color: var(--muted); font-style: italic; padding: 40px; text-align: center; }
    #toast {
      position: fixed; bottom: 18px; left: 50%; transform: translateX(-50%);
      background: var(--txt); color: #fff; border: 1px solid var(--txt); border-radius: 6px;
      padding: 8px 14px; font-size: 12px; opacity: 0; transition: opacity .2s; pointer-events: none; z-index: 100;
      box-shadow: 0 4px 12px rgba(16,24,40,.2);
    }
    #toast.show { opacity: 1; }
    #toast.err { background: #b42318; border-color: #b42318; }

    /* Panneau détail OF */
    #panel {
      position: fixed; top: 0; right: 0; height: 100vh; width: 320px;
      background: var(--panel); border-left: 1px solid var(--line);
      box-shadow: -4px 0 18px rgba(16,24,40,.12);
      transform: translateX(100%); transition: transform .18s ease; z-index: 80;
      display: flex; flex-direction: column; padding: 16px; overflow-y: auto;
    }
    #panel.open { transform: translateX(0); }
    .panel-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
    .p-num { font-size: 16px; font-weight: 700; color: var(--txt); }
    .p-art { font-size: 13px; color: var(--aldes); font-weight: 600; margin-top: 2px; }
    .p-close { background: none; border: none; color: var(--muted); font-size: 22px; line-height: 1; cursor: pointer; padding: 0 4px; }
    .p-close:hover { color: var(--txt); }
    .p-des { font-size: 12px; color: var(--muted); margin: 6px 0 14px; }

    .p-prog { margin-bottom: 16px; }
    .p-prog-bar { height: 10px; background: #e7eaf0; border-radius: 5px; overflow: hidden; }
    .p-prog-bar span { display: block; height: 100%; width: 0; background: var(--st1); transition: width .2s; }
    .p-prog-lbl { font-size: 11px; color: var(--muted); margin-top: 4px; }
    .p-prog-lbl span { color: var(--txt); font-weight: 600; }

    .p-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin: 0; font-size: 12px; }
    .p-grid dt { color: var(--muted); padding: 7px 0; border-bottom: 1px solid var(--line-soft); }
    .p-grid dd { margin: 0; text-align: right; color: var(--txt); font-weight: 600; padding: 7px 0; border-bottom: 1px solid var(--line-soft); font-variant-numeric: tabular-nums; }
    .p-note { margin-top: 12px; font-size: 12px; color: var(--txt); background: #fff7e6; border: 1px solid #f0d79a; border-radius: 4px; padding: 8px; display: none; }

    .bar.selected { outline: 2px solid var(--aldes); outline-offset: 0; z-index: 5; }

    /* Bouton + panneau backlog (OF en retard) */
    .backlog-btn {
      background: #fff4e5; color: #9a5b00; border: 1px solid #f0c98a; border-radius: 4px;
      padding: 5px 10px; font-size: 12px; cursor: pointer; white-space: nowrap;
    }
    .backlog-btn:hover { background: #ffe9cc; }
    .backlog-btn b { color: #b42318; }
    #backlog {
      position: fixed; top: 0; left: 0; height: 100vh; width: 300px;
      background: var(--panel); border-right: 1px solid var(--line);
      box-shadow: 4px 0 18px rgba(16,24,40,.12);
      transform: translateX(-100%); transition: transform .18s ease; z-index: 80;
      display: flex; flex-direction: column; padding: 14px; overflow-y: auto;
    }
    #backlog.open { transform: translateX(0); }
    .bk-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
    .bk-title { font-size: 14px; font-weight: 700; color: var(--txt); }
    .bk-sub { display: block; font-size: 11px; color: var(--muted); }
    .bk-hint { font-size: 11px; color: var(--muted); margin: 8px 0 12px; }
    #backlog-list { display: flex; flex-direction: column; gap: 6px; }
    .bk-empty { color: var(--muted); font-style: italic; font-size: 12px; }
    .bk-line { font-size: 10px; text-transform: uppercase; letter-spacing: .4px; color: var(--muted); margin: 8px 0 2px; }
    .card {
      display: flex; flex-direction: column; gap: 1px; line-height: 1.25;
      background: #fff; border: 1px solid var(--line); border-left: 3px solid var(--muted);
      border-radius: 4px; padding: 5px 8px; cursor: grab; user-select: none;
      box-shadow: 0 1px 2px rgba(16,24,40,.06);
    }
    .card:active { cursor: grabbing; }
    .card.dragging { opacity: .4; }
    .card.st-1 { border-left-color: var(--st1); }
    .card.st-2 { border-left-color: var(--st2); }
    .card.st-3 { border-left-color: var(--st3); }
    .card .num { font-weight: 600; color: var(--txt); font-size: 12px; }
    .card .art { color: var(--aldes); font-size: 11px; }
    .card .qty { color: var(--muted); font-size: 11px; }
    .card .c-late { font-size: 10px; color: #b42318; margin-top: 2px; }
    .bar .c-late { display: none; } /* masqué une fois replanifié (devenu barre) */
  </style>
</head>
<body>
  <header>
    <h1>Ordonnancement <b>OF</b></h1>
    <span id="board-meta" class="meta">{{ totalOf }} OF · {{ lineCount }} lignes · {{ horizon }} j</span>
    <div class="legend">
      <span><i class="dot" style="background:var(--st1)"></i>Ferme</span>
      <span><i class="dot" style="background:var(--st2)"></i>Planifié</span>
      <span><i class="dot" style="background:var(--st3)"></i>Suggéré</span>
    </div>
    <form method="get" action="/board" style="margin-left:auto"
          up-submit up-target="#board-main, #board-meta" up-history="true" up-scroll="false">
      <label class="meta">Début <input type="date" name="start" value="{{ start }}"></label>
      <label class="meta">Jours <input type="number" name="days" value="{{ horizon }}" min="1" max="90" style="width:58px"></label>
      <button type="submit">Afficher</button>
    </form>
  </header>

  <div class="toolbar">
    <input id="search" type="search" placeholder="Rechercher — ligne de production, OF ou article…" autocomplete="off">
    <span class="hint" id="search-hint"></span>
    <button type="button" id="backlog-btn" class="backlog-btn" style="display:none">⚠ Retard <b id="backlog-count">0</b></button>
    <label class="toggle" style="margin-left:auto">
      <input type="checkbox" id="span-toggle"> Étaler les OF sur leur durée
    </label>
  </div>

  <div id="board-main">
  <script type="application/json" id="board-data">{{{ boardDataJson }}}</script>
  <div class="gantt" style="--cols:{{ cols }}">
    @if(lines.length === 0)
      <div class="empty-board">Aucun OF planifiable dans la fenêtre (vérifier gamme / dates).</div>
    @else
      <div class="ghead">
        <div class="corner">
          <span class="ctop">Semaine</span>
          <span class="cbot">Ligne \ Jour · charge</span>
        </div>
        <div class="hstack">
          <div class="wrow">
            @each(w in weeks)
              <div class="wcell" style="flex:0 0 calc({{ w.span }} * var(--day-w))">S{{ w.num }}</div>
            @end
          </div>
          <div class="dcols">
            @each(d in days)
              <div class="dcol {{ d.weekStart && d.idx > 0 ? 'wk-start' : '' }}">
                <span class="dwd">{{ d.weekday }}</span>
                <span class="ddt">{{ d.dayNum }}</span>
                <span class="dh">{{ d.hours }} h</span>
              </div>
            @end
          </div>
        </div>
      </div>

      @each(line in lines)
        <div class="row" data-search="{{ (line.code + ' ' + line.label).toLowerCase() }}">
          <div class="lbl" title="{{ line.code }}">{{ line.label }}<span class="code">{{ line.code }}</span></div>
          <div class="track" data-col="{{ line.code }}"
               style="height:calc({{ line.laneCount }} * var(--lane-h) + 6px)">
            @each(d in days)
              @if(d.weekStart && d.idx > 0)
                <div class="wksep" style="left:calc({{ d.idx }} * var(--day-w))"></div>
              @end
            @end
            @each(lane in line.lanes)
              @each(b in lane.bars)
                <div class="bar st-{{ b.status }}{{ b.modified ? ' mod' : '' }}{{ b.contLeft ? ' cont-left' : '' }}{{ b.contRight ? ' cont-right' : '' }}"
                     draggable="true"
                     data-num-of="{{ b.numOf }}" data-art="{{ b.article }}" data-span="{{ b.spanDays }}"
                     data-start-idx="{{ b.startIdx }}" data-vspan="{{ b.span }}" data-hours="{{ b.hours }}"
                     style="left:calc({{ b.startIdx }} * var(--day-w)); width:calc({{ b.span }} * var(--day-w) - 5px); top:calc({{ lane.idx }} * var(--lane-h) + 3px)"
                     title="{{ b.numOf }} — {{ b.article }}{{ b.designation ? ' (' + b.designation + ')' : '' }}&#10;{{ b.statutLabel }} · ×{{ b.qty }}&#10;{{ b.startIso }} → {{ b.endIso }} ({{ b.spanDays }}j)">
                  <span class="num">{{ b.numOf }}</span><span class="art">{{ b.article }}</span><span class="qty">×{{ b.qty }}</span>
                </div>
              @end
            @end
          </div>
        </div>
      @end
    @end
  </div>
  </div>

  <div id="toast"></div>

  <aside id="panel" aria-hidden="true">
    <div class="panel-head">
      <div>
        <div class="p-num" id="p-num">—</div>
        <div class="p-art" id="p-art"></div>
      </div>
      <button class="p-close" id="p-close" title="Fermer">×</button>
    </div>
    <div class="p-des" id="p-des"></div>

    <div class="p-prog">
      <div class="p-prog-bar"><span id="p-prog-fill"></span></div>
      <div class="p-prog-lbl"><span id="p-prog-pct">0%</span> réalisé</div>
    </div>

    <dl class="p-grid">
      <dt>Statut</dt><dd id="p-statut">—</dd>
      <dt>Type OF</dt><dd id="p-type">—</dd>
      <dt>Ligne</dt><dd id="p-line">—</dd>
      <dt>Début</dt><dd id="p-start">—</dd>
      <dt>Fin</dt><dd id="p-end">—</dd>
      <dt>Durée</dt><dd id="p-span">—</dd>
      <dt>Charge</dt><dd id="p-hours">—</dd>
      <dt>Qté lancée</dt><dd id="p-qlaunch">—</dd>
      <dt>Qté réalisée</dt><dd id="p-qdone">—</dd>
      <dt>Reste à produire</dt><dd id="p-qrem">—</dd>
    </dl>
    <div class="p-note" id="p-note"></div>
  </aside>

  <aside id="backlog" aria-hidden="true">
    <div class="bk-head">
      <div><span class="bk-title">OF en retard</span> <span class="bk-sub">non planifiés dans la fenêtre</span></div>
      <button class="p-close" id="bk-close" title="Fermer">×</button>
    </div>
    <div class="bk-hint">Glisser un OF sur sa ligne pour le replanifier.</div>
    <div id="backlog-list"></div>
  </aside>

  <script>
    // État board, rechargé depuis #board-data à chaque swap de fragment Unpoly.
    let DAYS = []
    let OFDATA = {}
    let COLS = 0
    function loadBoardData() {
      const el = document.getElementById('board-data')
      if (!el) return
      try {
        const d = JSON.parse(el.textContent)
        DAYS = d.days || []
        OFDATA = d.ofData || {}
        COLS = d.cols || DAYS.length
        window.DAYS = DAYS
        window.OFDATA = OFDATA
      } catch (_e) { /* ignore */ }
    }
    loadBoardData()

    const toast = (msg, err) => {
      const t = document.getElementById('toast')
      t.textContent = msg
      t.className = 'show' + (err ? ' err' : '')
      clearTimeout(t._h)
      t._h = setTimeout(() => (t.className = ''), 2500)
    }

    // Largeur réelle d'un jour, mesurée sur la piste (--day-w est un calc() non résoluble en JS).
    const dayWidthOf = (track) => track.getBoundingClientRect().width / COLS

    // iso (local) + n days → iso
    const addIso = (iso, n) => {
      const [y, m, d] = iso.split('-').map(Number)
      const dt = new Date(y, m - 1, d)
      dt.setDate(dt.getDate() + n)
      const p = (x) => String(x).padStart(2, '0')
      return dt.getFullYear() + '-' + p(dt.getMonth() + 1) + '-' + p(dt.getDate())
    }

    /* ---------- Drag & drop ---------- */
    let dragged = null
    document.addEventListener('dragstart', (e) => {
      const el = e.target.closest('.bar, .card')
      if (!el) return
      dragged = el
      el.classList.add('dragging')
      e.dataTransfer.effectAllowed = 'move'
      e.dataTransfer.setData('text/plain', el.dataset.numOf)
    })
    document.addEventListener('dragend', (e) => {
      const el = e.target.closest('.bar, .card')
      if (el) el.classList.remove('dragging')
      dragged = null
    })

    // Zones de drop déléguées au document (résistent aux swaps de fragment).
    document.addEventListener('dragover', (e) => {
      const z = e.target.closest('.track')
      if (!z) return
      // Autorisé uniquement sur la ligne d'origine de l'OF (pas de saut de ligne).
      if (!dragged || lineOf(dragged) !== z.dataset.col) { e.dataTransfer.dropEffect = 'none'; return }
      e.preventDefault()
      z.classList.add('drop-hover')
    })
    document.addEventListener('dragleave', (e) => {
      const z = e.target.closest('.track')
      if (z) z.classList.remove('drop-hover')
    })
    document.addEventListener('drop', (e) => {
      const z = e.target.closest('.track')
      if (!z) return
      e.preventDefault()
      z.classList.remove('drop-hover')
      onDrop(z, e)
    })

    // Re-calcule l'empilement (lanes) des barres d'une piste + sa hauteur.
    // En compact, chaque OF occupe 1 colonne (jour de début) → empilement serré.
    const relayout = (track) => {
      if (!track) return
      const compact = document.querySelector('.gantt')?.classList.contains('compact')
      const bars = [...track.querySelectorAll('.bar')]
      bars.sort((a, b) =>
        (+a.dataset.startIdx) - (+b.dataset.startIdx) || (+b.dataset.vspan) - (+a.dataset.vspan))
      const laneEnds = []
      for (const bar of bars) {
        const s = +bar.dataset.startIdx
        const sp = compact ? 1 : Math.max(1, +bar.dataset.vspan)
        let lane = laneEnds.findIndex((end) => end < s)
        if (lane === -1) { lane = laneEnds.length; laneEnds.push(-1) }
        laneEnds[lane] = s + sp - 1
        bar.style.top = 'calc(' + lane + ' * var(--lane-h) + 3px)'
        bar.style.left = 'calc(' + s + ' * var(--day-w))'
        bar.style.width = 'calc(' + sp + ' * var(--day-w) - 5px)'
      }
      track.style.height = 'calc(' + Math.max(1, laneEnds.length) + ' * var(--lane-h) + 6px)'
    }
    const relayoutAll = () => document.querySelectorAll('.track').forEach(relayout)

    // Place une barre (déplacée / replanifiée) dans une piste.
    const placeBar = (el, startIdx, vspan, contRight) => {
      el.classList.remove('card')
      el.classList.add('bar', 'mod')
      el.classList.toggle('cont-right', contRight)
      el.classList.remove('cont-left')
      el.dataset.startIdx = startIdx
      el.dataset.vspan = vspan
    }

    // Ligne d'origine d'un élément : carte backlog → data-line ; barre → piste.
    const lineOf = (el) =>
      el.classList.contains('card') ? el.dataset.line : el.closest('.track')?.dataset.col

    async function onDrop(zone, e) {
      if (!dragged) return
      const el = dragged
      const fromTrack = el.closest('.track')
      // Sécurité : seulement sur la ligne d'origine de l'OF.
      if (lineOf(el) !== zone.dataset.col) { toast('Déplacement uniquement sur la ligne de l\'OF', true); return }
      const numOf = el.dataset.numOf
      const fullSpan = Math.max(1, parseInt(el.dataset.span || '1', 10))

      // Snapshot pour rollback
      const snap = { parent: el.parentNode, next: el.nextSibling, cls: el.className, style: el.style.cssText }

      const rect = zone.getBoundingClientRect()
      const startIdx = Math.min(COLS - 1, Math.max(0, Math.floor((e.clientX - rect.left) / dayWidthOf(zone))))
      const startIso = window.DAYS[startIdx]
      const endIso = addIso(startIso, fullSpan - 1)
      // Largeur = nb de colonnes (jours ouvrés) couvertes par [startIso, endIso]
      let vspan = 1
      while (startIdx + vspan < COLS && window.DAYS[startIdx + vspan] <= endIso) vspan++
      placeBar(el, startIdx, vspan, endIso > window.DAYS[COLS - 1])
      zone.appendChild(el)

      // Re-layout immédiat (optimiste)
      if (fromTrack && fromTrack !== zone) relayout(fromTrack)
      relayout(zone)

      try {
        const res = await fetch('/api/v1/planning-board/ofs/' + encodeURIComponent(numOf), {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ workstation: zone.dataset.col, dateDebut: startIso, dateFin: endIso }),
        })
        if (!res.ok) throw new Error('HTTP ' + res.status)
        // MAJ données panneau (ligne + dates) pour cet OF
        if (window.OFDATA[numOf]) {
          window.OFDATA[numOf].workstation = zone.dataset.col
          window.OFDATA[numOf].startIso = startIso
          window.OFDATA[numOf].endIso = endIso
        }
        if (panelNum === numOf) openPanel(numOf)
        buildBacklog() // l'OF replanifié n'est peut-être plus en retard
        toast(numOf + ' → ' + zone.dataset.col + ' · ' + startIso)
      } catch (err) {
        // Rollback DOM
        el.className = snap.cls
        el.style.cssText = snap.style
        if (snap.next) snap.parent.insertBefore(el, snap.next)
        else snap.parent.appendChild(el)
        if (fromTrack) relayout(fromTrack)
        relayout(zone)
        toast('Échec : ' + err.message, true)
      }
      recomputeCharge()
    }

    /* ---------- Recherche multifonction ---------- */
    const search = document.getElementById('search')
    const hint = document.getElementById('search-hint')
    function applyFilter() {
      const q = search.value.trim().toLowerCase()
      let matches = 0
      document.querySelectorAll('.bar').forEach((el) => {
        const hay = (el.dataset.numOf + ' ' + el.dataset.art).toLowerCase()
        const ok = !q || hay.includes(q)
        el.classList.toggle('dim', !!q && !ok)
        if (q && ok) matches++
      })
      document.querySelectorAll('.row').forEach((row) => {
        if (!q) { row.classList.remove('hide'); return }
        const lineMatch = row.dataset.search.includes(q)
        if (lineMatch) {
          row.querySelectorAll('.bar').forEach((b) => b.classList.remove('dim'))
          row.classList.remove('hide')
          return
        }
        row.classList.toggle('hide', !row.querySelector('.bar:not(.dim)'))
      })
      hint.textContent = q ? matches + ' OF trouvé(s)' : ''
      recomputeCharge()
    }
    search.addEventListener('input', applyFilter)

    /* ---------- Étalement multi-jours (toggle) ---------- */
    const spanToggle = document.getElementById('span-toggle')
    spanToggle.checked = localStorage.getItem('board-span') === '1'
    function applySpan() {
      const g = document.querySelector('.gantt')
      if (g) g.classList.toggle('compact', !spanToggle.checked)
    }
    spanToggle.addEventListener('change', () => {
      localStorage.setItem('board-span', spanToggle.checked ? '1' : '0')
      applySpan()
      relayoutAll()
    })

    /* ---------- Charge dynamique (selon barres visibles) ---------- */
    function recomputeCharge() {
      const totals = new Array(COLS).fill(0)
      document.querySelectorAll('.bar').forEach((bar) => {
        if (bar.classList.contains('dim')) return
        const row = bar.closest('.row')
        if (row && row.classList.contains('hide')) return
        const s = +bar.dataset.startIdx
        if (s >= 0 && s < COLS) totals[s] += +bar.dataset.hours || 0
      })
      document.querySelectorAll('.dcol').forEach((dc, i) => {
        const dh = dc.querySelector('.dh')
        if (dh) dh.textContent = Math.round(totals[i] || 0) + ' h'
      })
    }

    /* ---------- Panneau détail OF ---------- */
    const panel = document.getElementById('panel')
    let panelNum = null
    const fr = (n) => (n == null ? '—' : new Intl.NumberFormat('fr-FR').format(n))
    const setTxt = (id, v) => { document.getElementById(id).textContent = v }

    function openPanel(numOf) {
      const d = window.OFDATA[numOf]
      if (!d) return
      panelNum = numOf
      const launched = d.qtyLaunched || 0
      const pct = launched > 0 ? Math.min(100, Math.round((d.qtyDone / launched) * 100)) : 0
      setTxt('p-num', d.numOf)
      setTxt('p-art', d.article)
      const des = document.getElementById('p-des')
      des.textContent = d.designation || ''
      des.style.display = d.designation ? '' : 'none'
      document.getElementById('p-prog-fill').style.width = pct + '%'
      setTxt('p-prog-pct', pct + '%')
      setTxt('p-statut', d.statutLabel || '—')
      setTxt('p-type', d.typeOfLabel || '—')
      setTxt('p-line', d.workstationLabel ? d.workstationLabel + ' (' + d.workstation + ')' : (d.workstation || '—'))
      setTxt('p-start', d.startIso || '—')
      setTxt('p-end', d.endIso || '—')
      setTxt('p-span', (d.spanDays || 1) + ' j')
      setTxt('p-hours', (d.hours || 0) + ' h')
      const u = d.unit ? ' ' + d.unit : ''
      setTxt('p-qlaunch', fr(launched) + u)
      setTxt('p-qdone', fr(d.qtyDone) + u)
      setTxt('p-qrem', fr(d.qtyRemaining) + u)
      const note = document.getElementById('p-note')
      note.textContent = d.note || ''
      note.style.display = d.note ? 'block' : 'none'
      panel.classList.add('open')
      panel.setAttribute('aria-hidden', 'false')
      document.querySelectorAll('.bar.selected').forEach((b) => b.classList.remove('selected'))
      const bar = document.querySelector('.bar[data-num-of="' + (window.CSS && CSS.escape ? CSS.escape(numOf) : numOf) + '"]')
      if (bar) bar.classList.add('selected')
    }
    function closePanel() {
      panel.classList.remove('open')
      panel.setAttribute('aria-hidden', 'true')
      panelNum = null
      document.querySelectorAll('.bar.selected').forEach((b) => b.classList.remove('selected'))
    }
    document.getElementById('p-close').addEventListener('click', closePanel)
    document.addEventListener('click', (e) => {
      const bar = e.target.closest('.bar')
      if (bar) { openPanel(bar.dataset.numOf); return }
      if (!e.target.closest('#panel')) closePanel()
    })

    /* ---------- Init / ré-init après swap Unpoly ---------- */
    function initBoard() {
      loadBoardData()  // recharge DAYS/OFDATA/COLS depuis #board-data
      applySpan()      // applique le mode compact au nouveau .gantt
      relayoutAll()    // empilement correct selon le mode (compact = 1 colonne)
      applyFilter()    // réapplique le filtre + recalcule la charge
      closePanel()     // l'OF sélectionné peut ne plus exister
    }
    if (window.up && up.compiler) {
      // Exécuté au boot ET à chaque insertion de #board-main (swap formulaire).
      up.compiler('#board-main', initBoard)
    } else {
      initBoard()
    }
  </script>
</body>
</html>
