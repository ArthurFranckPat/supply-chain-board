<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title inertia>Ordonnancement</title>

  {{-- Webfonts (Hanken Grotesk / Inter / JetBrains Mono / Material Symbols).
       Le bundle Tailwind (app.css) est servi par @vite ci-dessous. --}}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;600;700;900&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap"
    rel="stylesheet"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0&display=swap"
    rel="stylesheet"
  />

  @inertiaHead()
  @vite(['inertia/app/app.tsx'])
</head>
<body>
  @inertia()
</body>
</html>
