<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title inertia>Ordonnancement (React)</title>

  {{-- Webfonts (Inter / Material Symbols).
       Thème Sage Carbon officiel : plus de Fraunces ou Hanken Grotesk. --}}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap"
    rel="stylesheet"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0&display=swap"
    rel="stylesheet"
  />

  @inertiaHead()
  @viteReactRefresh()
  @vite(['inertia-react/app.tsx'])
</head>
<body>
  @inertia()
</body>
</html>
