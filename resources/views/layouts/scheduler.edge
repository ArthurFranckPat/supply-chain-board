<!DOCTYPE html>
<html lang="fr" class="theme-m3">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;600;700;900&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0&display=swap" rel="stylesheet">
  <script src="/vendor/unpoly.js"></script>
  <link rel="stylesheet" href="/vendor/unpoly.css">
  <link rel="stylesheet" href="/css/app.css">
  <script src="/js/app.js" defer></script>
</head>
<body class="font-body-md text-on-surface antialiased m-0 bg-background">
  {{{ await $slots.main() }}}
  <script>
    // Recherche live avec portée (scope) sélectionnable via #board-search-scope.
    //   poste     → poste de charge (data-wst, data-wst-name, data-line)
    //   of        → numéro d'OF (data-num-of, texte carte)
    //   pf        → article produit fini (data-art)
    //   composant → articles parents qui consomment le composant (API, async)
    // Une ligne (poste) reste visible si elle matche OU contient ≥1 carte matchée.
    // Dans une ligne visible, les cartes non matchées sont estompées (opacity .15).
    ;(function () {
      var SCOPE_DEFAULT = 'poste'
      var lastQuery = ''
      var lastScope = SCOPE_DEFAULT
      // Cache : composant → Set d'articles parents (PF) qui le consomment.
      var componentCache = new Map()
      // Articles matchés pour la requête composant en cours (null = pas de scope composant).
      var componentMatch = null

      function currentScope() {
        var sel = document.getElementById('board-search-scope')
        return sel ? sel.value : SCOPE_DEFAULT
      }

      function applyFilter() {
        var input = document.getElementById('board-search')
        if (!input) return
        var q = input.value.trim().toLowerCase()
        var scope = currentScope()
        document.querySelectorAll('.sch-row').forEach(function (row) {
          var lineHay = (row.getAttribute('data-line') || '').toLowerCase()
          var lineMatch = !q || (scope === 'poste' && lineHay.indexOf(q) !== -1)
          var anyCard = false
          row.querySelectorAll('.sch-of-card').forEach(function (el) {
            var hay = (
              (el.textContent || '') + ' ' +
              (el.getAttribute('data-num-of') || '') + ' ' +
              (el.getAttribute('data-wst') || '') + ' ' +
              (el.getAttribute('data-wst-name') || '') + ' ' +
              (el.getAttribute('data-art') || '')
            ).toLowerCase()
            var num = (el.getAttribute('data-num-of') || '').toLowerCase()
            var art = (el.getAttribute('data-art') || '').toLowerCase()
            var wst = (el.getAttribute('data-wst') || '').toLowerCase()
            var wstName = (el.getAttribute('data-wst-name') || '').toLowerCase()
            var cardMatch = !q
            if (q) {
              if (scope === 'poste') {
                cardMatch = lineMatch || wst.indexOf(q) !== -1 || wstName.indexOf(q) !== -1 || num.indexOf(q) !== -1
              } else if (scope === 'of') {
                cardMatch = num.indexOf(q) !== -1 || hay.indexOf(q) !== -1
              } else if (scope === 'pf') {
                cardMatch = art.indexOf(q) !== -1
              } else if (scope === 'composant') {
                // componentMatch est un Set d'articles parents ; null pendant le chargement.
                cardMatch = componentMatch !== null && componentMatch.has(el.getAttribute('data-art') || '')
              }
            }
            el.style.opacity = cardMatch ? '' : '0.15'
            el.dataset.match = cardMatch ? '1' : '0'
            if (q && cardMatch) anyCard = true
          })
          row.style.display = (!q || lineMatch || anyCard) ? '' : 'none'
        })
        recomputeDayLoad()
      }

      // Recherche par composant : interroge l'API (avec cache), reconstruit le Set
      // d'articles parents, puis ré-applique le filtre.
      function runComponentSearch(q) {
        if (!q) { componentMatch = new Set(); applyFilter(); return }
        if (componentCache.has(q)) {
          componentMatch = componentCache.get(q)
          applyFilter()
          return
        }
        // En attendant la réponse : aucune carte ne matche (tout estompé).
        componentMatch = null
        applyFilter()
        fetch('/api/v1/planning-board/articles-by-component/' + encodeURIComponent(q.toUpperCase()))
          .then(function (r) { return r.ok ? r.json() : { articles: [] } })
          .then(function (data) {
            var set = new Set(data.articles || [])
            componentCache.set(q, set)
            // Vérifie qu'on est toujours sur la même requête (l'user a pu retaper).
            var input = document.getElementById('board-search')
            if (input && input.value.trim().toLowerCase() === q && currentScope() === 'composant') {
              componentMatch = set
              applyFilter()
            }
          })
          .catch(function () {
            var set = new Set()
            componentCache.set(q, set)
            if (currentScope() === 'composant') { componentMatch = set; applyFilter() }
          })
      }

      // ⌘K / Ctrl+K focus search; Esc clears + blurs.
      window.addEventListener('keydown', function (e) {
        var input = document.getElementById('board-search')
        if (!input) return
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
          e.preventDefault(); input.focus(); input.select()
        } else if (e.key === 'Escape' && document.activeElement === input) {
          input.value = ''; componentMatch = null; applyFilter(); input.blur()
        }
      })

      // Changement de portée → ré-applique le filtre avec la même requête.
      document.addEventListener('change', function (e) {
        if (!e.target || e.target.id !== 'board-search-scope') return
        var input = document.getElementById('board-search')
        if (!input) return
        var q = input.value.trim().toLowerCase()
        lastScope = e.target.value
        if (!q) return
        if (e.target.value === 'composant') {
          runComponentSearch(q)
        } else {
          componentMatch = null
          applyFilter()
        }
      })

      // Document-delegated input handler — survives Unpoly fragment swaps.
      document.addEventListener('input', function (e) {
        if (!e.target || e.target.id !== 'board-search') return
        var q = e.target.value.trim().toLowerCase()
        lastQuery = e.target.value
        var scope = currentScope()
        if (scope === 'composant' && q) {
          runComponentSearch(q)
        } else {
          componentMatch = null
          applyFilter()
        }
      })

      // Day-header load : somme live depuis le DOM (suit les drag&drop, respecte le filtre).
      function recomputeDayLoad() {
        var sums = {}
        document.querySelectorAll('.sch-cal-cell').forEach(function (cell) {
          var row = cell.closest('.sch-row')
          if (row && row.style.display === 'none') return
          var col = cell.dataset.col
          cell.querySelectorAll('.sch-of-card').forEach(function (card) {
            if (card.dataset.match === '0') return
            var h = parseFloat(card.dataset.hours || '0')
            sums[col] = (sums[col] || 0) + h
          })
        })
        document.querySelectorAll('.sch-day-load').forEach(function (el) {
          var v = sums[el.dataset.col] || 0
          el.textContent = (Math.round(v * 10) / 10) + 'h'
        })
      }

      // Garde le filtre actif à travers les swaps Unpoly (horizon, prev/next) :
      // restore query + scope, et relance la recherche composant si besoin.
      if (window.up && window.up.on) {
        window.up.on('up:fragment:inserted', function () {
          var input = document.getElementById('board-search')
          var sel = document.getElementById('board-search-scope')
          if (sel && lastScope) sel.value = lastScope
          if (!input || !lastQuery) return
          input.value = lastQuery
          var q = lastQuery.trim().toLowerCase()
          if (currentScope() === 'composant' && q) runComponentSearch(q)
          else { componentMatch = null; applyFilter() }
        })
      }
    })()
  </script>
</body>
</html>