<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>X3 Debug — Modèles</title>
  <script src="https://unpkg.com/unpoly@3/unpoly.min.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/unpoly@3/unpoly.min.css">
  <style>
    * { box-sizing: border-box; }
    body { font-family: monospace; font-size: 13px; background: #0f0f0f; color: #e0e0e0; margin: 0; padding: 0; }

    nav {
      position: sticky; top: 0; z-index: 100;
      background: #111; border-bottom: 1px solid #2a2a2a;
      padding: 10px 20px; display: flex; gap: 8px; flex-wrap: wrap; align-items: center;
    }
    nav strong { color: #7eb8f7; margin-right: 8px; }
    nav a { color: #888; text-decoration: none; font-size: 11px; padding: 2px 6px; border: 1px solid #333; border-radius: 3px; }
    nav a:hover { color: #aef; border-color: #aef; }

    main { padding: 20px; }
    h1 { color: #7eb8f7; margin-bottom: 24px; }

    .section { margin-bottom: 40px; scroll-margin-top: 52px; }
    .section-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; border-bottom: 1px solid #333; padding-bottom: 4px; }
    h2 { color: #aef; font-size: 14px; margin: 0; flex: 1; }

    .reload-btn { color: #555; font-size: 11px; padding: 1px 6px; border: 1px solid #333; border-radius: 3px; cursor: pointer; background: none; }
    .reload-btn:hover { color: #aef; border-color: #aef; }
    .reload-btn:disabled { opacity: 0.4; cursor: default; }

    table { border-collapse: collapse; width: 100%; }
    th { background: #1e1e1e; color: #888; text-align: left; padding: 4px 10px; border: 1px solid #2a2a2a; font-weight: normal; }
    td { padding: 4px 10px; border: 1px solid #1e1e1e; color: #cfc; white-space: nowrap; }
    tr:nth-child(even) td { background: #0d0d0d; }
    .empty { color: #555; font-style: italic; }
    .error { color: #f77; font-style: italic; }
    .loading { color: #555; font-style: italic; padding: 8px 0; }
  </style>
</head>
<body>
  <nav>
    <strong>X3 Debug</strong>
    @each(m in allModels)
      <a href="#section-{{ m.key }}">{{ m.key }}</a>
    @end
  </nav>

  <main>
    <h1>X3 — 5 premières lignes par modèle</h1>

    @each(m in allModels)
      <div class="section" id="section-{{ m.key }}">
        <div class="section-header">
          <h2>{{ m.title }}</h2>
          <button class="reload-btn" onclick="loadSection('{{ m.key }}')">↻ recharger</button>
        </div>
        <p class="loading">Chargement…</p>
      </div>
    @end
  </main>

  <script>
    function loadSection(key) {
      up.render({
        target: '#section-' + key,
        url: '/debug/x3?model=' + key,
        timeout: 30000,
        scroll: false,
      })
    }

    async function loadQueue(keys, concurrency) {
      var i = 0
      async function next() {
        if (i >= keys.length) return
        var key = keys[i++]
        await up.render({ target: '#section-' + key, url: '/debug/x3?model=' + key, timeout: 30000, scroll: false }).catch(function(){})
        return next()
      }
      var workers = []
      for (var w = 0; w < concurrency; w++) workers.push(next())
      await Promise.all(workers)
    }

    document.addEventListener('up:framework:ready', function () {
      var keys = Array.from(document.querySelectorAll('.section[id^="section-"]')).map(function(el) {
        return el.id.replace('section-', '')
      })
      loadQueue(keys, 3)
    })
  </script>
</body>
</html>
